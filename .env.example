# ─── Application ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MediaGrab

# ─── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=15
RATE_LIMIT_WINDOW_MS=60000

# ─── Upload limits (in bytes) — 50 MB ────────────────────────────
MAX_UPLOAD_SIZE=52428800

# ─── yt-dlp path ─────────────────────────────────────────────────
# If yt-dlp is in your system PATH you can leave this as "yt-dlp".
# Otherwise set the full path, e.g. /usr/local/bin/yt-dlp
YTDLP_PATH=yt-dlp

# ─── FFmpeg / FFprobe paths ──────────────────────────────────────
# Same logic: leave as "ffmpeg" if it's in PATH,
# otherwise set the full path.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe